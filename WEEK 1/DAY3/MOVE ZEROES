
class Solution {
    public void moveZeroes(int[] nums) {
        int emptySeat = 0;
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] != 0) {
                nums[emptySeat] = nums[i];
                emptySeat = emptySeat + 1;
            }
        }
        while (emptySeat < nums.length) {
            nums[emptySeat] = 0;
            emptySeat = emptySeat + 1;
        }
    }
}