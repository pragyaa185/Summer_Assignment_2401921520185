
class Solution {
    public void reverseString(char[] s) {
        int leftIdx = 0;
        int rightIdx = s.length - 1;
        
        while (leftIdx < rightIdx) {
            char safeBox = s[leftIdx];
            s[leftIdx] = s[rightIdx];
            s[rightIdx] = safeBox;
            
            leftIdx = leftIdx + 1;
            rightIdx = rightIdx - 1;
        }
    }
}